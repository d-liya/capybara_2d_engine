{
  "name": "capybara_2d_engine",
  "version": "1.0.0",
  "description": "Capybara Game template visit https://developer.capybara.build to learn more",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently -k -n css,js,open -c yellow,cyan,green \"npm run dev:css\" \"npm run dev:js\" \"npm run dev:open\"",
    "dev:css": "npm run build:css && tsx scripts/build-css.ts --watch",
    "dev:js": "esbuild src/main.ts --bundle --format=esm --platform=browser --target=es2022 --minify --legal-comments=none --outfile=dist/main.js --servedir=. --serve=0.0.0.0:3000 --watch=forever",
    "dev:open": "node scripts/dev-open.mjs",
    "build:css": "tsx scripts/build-css.ts",
    "build": "npm run typecheck && npm run bundle",
    "bundle": "rm -rf dist && tsx scripts/build.ts",
    "build:watch": "npm run typecheck:watch & npm run bundle:watch",
    "typecheck": "tsc -p . --noEmit",
    "typecheck:watch": "tsc -p . --noEmit --watch"
  },
  "author": "Capybara Game Team",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.9.0",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/pathfinding": "^0.1.0",
    "pathfinding": "^0.4.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0"
  }
}
